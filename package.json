{
  "name": "agent-cli-proxy",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": false,
  "bin": {
    "agent-cli-proxy": "./dist/cli.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts src/cli.ts --target=bun --outdir=./dist && rm -rf dist/migrations && cp -R src/storage/migrations dist/migrations && mkdir -p dist/data && cp data/plans.default.json dist/data/plans.default.json",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e/",
    "test:e2e:mock": "MOCK_CLI_PROXY=1 CLI_PROXY_API_URL=http://localhost:18317 bun test tests/e2e/",
    "start": "bun run dist/index.js",
    "backfill:costs": "bun run src/cli.ts backfill-costs --env .env"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@tokscale/core": "^1.4.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {}
}
