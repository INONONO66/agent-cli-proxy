[Unit]
Description=Agent CLI Proxy
After=network.target

[Service]
Type=simple
User=agent-proxy
WorkingDirectory=/opt/agent-cli-proxy
ExecStart=/usr/bin/env bun run dist/index.js
Restart=always
RestartSec=5
Environment="NODE_ENV=production"
EnvironmentFile=/opt/agent-cli-proxy/.env

[Install]
WantedBy=multi-user.target
