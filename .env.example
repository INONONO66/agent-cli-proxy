PROXY_PORT=3100
PROXY_HOST=127.0.0.1
ADMIN_API_KEY=
CLI_PROXY_API_URL=http://localhost:8317
CLAUDE_CODE_VERSION=2.1.87
DB_PATH=data/proxy.db
PRICING_CACHE_TTL_MS=3600000
PRICING_CACHE_PATH=data/pricing-cache.json

# Custom client name mapping (optional)
# Format: api_key1=name1,api_key2=name2
# Example: sk-ant-api-abc123=종이,sk-ant-api-def456=복이
CLIENT_NAME_MAPPING=

# Optional CLIProxyAPI management correlation for per-account attribution
CLIPROXY_MGMT_KEY=
CLIPROXY_CORRELATION_INTERVAL_MS=15000
CLIPROXY_CORRELATION_LOOKBACK_MS=300000

# Optional: read CLIProxyAPI OAuth auth files to refresh subscription quotas.
# Needed for /admin/quotas to query Claude/Codex/Kimi quota endpoints.
CLIPROXY_AUTH_DIR=
QUOTA_REFRESH_TIMEOUT_MS=15000
